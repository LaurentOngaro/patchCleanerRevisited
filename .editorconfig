root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# PowerShell files: keep CRLF for Windows PowerShell 5.1 compatibility.
# UTF-8 with BOM is required for non-ASCII glyphs (e.g. "↻") to render correctly,
# but BOM is the responsibility of the editor that saves the file, not of the
# formatter. Keep `charset = utf-8` here so editors do not silently rewrite
# existing PowerShell files on save.
[*.{ps1,psm1,psd1}]
charset = utf-8
end_of_line = crlf
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false