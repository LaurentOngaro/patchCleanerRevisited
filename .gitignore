# Build outputs
*.exe
*.dll
*.pdb
*.zip
*.7z
*.tar.gz

# PowerShell
# Note: PowerShell scripts in this repo MUST be saved with UTF-8 BOM so that
# non-ASCII glyphs (e.g. "↻") render correctly on Windows PowerShell 5.1.
*.tmp
*.log

# Local config generated by the application (created on first close)
etc/patchCleanerRevisited_config.json

# Leftovers backup temp folder (created at runtime by the Leftovers Scanner)
WindowsPatchCleaner_Leftovers_*/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Publishing templates and contest-specific notes live under social/.
